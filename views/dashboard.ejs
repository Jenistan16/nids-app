<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — NIDS.AI</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
  <style>
    :root{--bg:#050a0f;--surface:#0b1421;--surface2:#0f1e30;--accent:#00d4ff;--accent2:#ff3c6e;--accent3:#7b2fff;--text:#e8edf2;--muted:#6b7f99;--border:rgba(0,212,255,0.12);--success:#22c55e;--warning:#f59e0b}
    *{margin:0;padding:0;box-sizing:border-box}
    body{background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;min-height:100vh;display:flex}

    /* Sidebar */
    .sidebar{width:240px;min-height:100vh;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;z-index:50}
    .sidebar-logo{padding:1.5rem;border-bottom:1px solid var(--border)}
    .sidebar-logo a{font-family:'Space Mono',monospace;font-size:1rem;font-weight:700;color:var(--accent);text-decoration:none}
    .sidebar-logo a span{color:var(--accent2)}
    .sidebar-nav{flex:1;padding:1rem 0}
    .nav-section{padding:.5rem 1rem .25rem;font-family:'Space Mono',monospace;font-size:.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em}
    .nav-item{display:flex;align-items:center;gap:.75rem;padding:.7rem 1.25rem;color:var(--muted);text-decoration:none;font-size:.88rem;transition:all .2s;border-left:3px solid transparent;margin:1px 0}
    .nav-item:hover,.nav-item.active{color:var(--text);background:rgba(0,212,255,.06);border-left-color:var(--accent)}
    .nav-item .icon{width:18px;text-align:center;font-size:1rem}
    .sidebar-footer{padding:1.25rem;border-top:1px solid var(--border)}
    .user-info{display:flex;align-items:center;gap:.75rem;margin-bottom:1rem}
    .avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent3));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;overflow:hidden;flex-shrink:0}
    .avatar img{width:100%;height:100%;object-fit:cover}
    .user-name{font-size:.85rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .user-email{font-size:.72rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .btn-logout{display:block;text-align:center;background:rgba(255,60,110,.1);border:1px solid rgba(255,60,110,.25);color:var(--accent2);padding:.5rem;border-radius:6px;font-size:.8rem;text-decoration:none;transition:background .2s}
    .btn-logout:hover{background:rgba(255,60,110,.2)}

    /* Main content */
    .main{margin-left:240px;flex:1;padding:2rem}
    .page-header{margin-bottom:2rem}
    .page-header h1{font-size:1.8rem;font-weight:800}
    .page-header p{color:var(--muted);margin-top:.25rem;font-size:.9rem}
    .greeting-time{font-family:'Space Mono',monospace;font-size:.75rem;color:var(--accent);margin-bottom:.5rem}

    /* Stats grid */
    .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:2rem}
    .stat-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:1.5rem;position:relative;overflow:hidden}
    .stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
    .stat-card.total::before{background:var(--accent)}
    .stat-card.attacks::before{background:var(--accent2)}
    .stat-card.normal::before{background:var(--success)}
    .stat-card.rate::before{background:var(--warning)}
    .stat-label{font-family:'Space Mono',monospace;font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.75rem}
    .stat-value{font-size:2.2rem;font-weight:800;line-height:1}
    .stat-value.accent{color:var(--accent)}
    .stat-value.red{color:var(--accent2)}
    .stat-value.green{color:var(--success)}
    .stat-value.yellow{color:var(--warning)}
    .stat-sub{font-size:.78rem;color:var(--muted);margin-top:.5rem}

    /* Charts */
    .charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:2rem}
    .chart-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:1.5rem}
    .chart-title{font-size:.9rem;font-weight:700;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem}
    .chart-title::before{content:'';display:inline-block;width:3px;height:14px;background:var(--accent);border-radius:2px}

    /* Recent predictions */
    .section-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:1.5rem;margin-bottom:1.5rem}
    .section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem}
    .section-header h3{font-size:1rem;font-weight:700}
    .see-all{font-size:.8rem;color:var(--accent);text-decoration:none}
    .see-all:hover{text-decoration:underline}
    table{width:100%;border-collapse:collapse}
    th{font-family:'Space Mono',monospace;font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);padding:.5rem .75rem;text-align:left;border-bottom:1px solid var(--border)}
    td{padding:.75rem;font-size:.85rem;border-bottom:1px solid rgba(255,255,255,.04)}
    tr:last-child td{border-bottom:none}
    .badge{display:inline-flex;align-items:center;gap:.3rem;padding:.25rem .6rem;border-radius:100px;font-size:.72rem;font-weight:600}
    .badge-attack{background:rgba(255,60,110,.12);color:var(--accent2);border:1px solid rgba(255,60,110,.25)}
    .badge-normal{background:rgba(34,197,94,.12);color:var(--success);border:1px solid rgba(34,197,94,.25)}
    .badge-dos{background:rgba(251,146,60,.12);color:#fb923c;border:1px solid rgba(251,146,60,.25)}
    .badge-probe{background:rgba(0,212,255,.12);color:var(--accent);border:1px solid rgba(0,212,255,.25)}
    .badge-r2l{background:rgba(123,47,255,.12);color:var(--accent3);border:1px solid rgba(123,47,255,.25)}
    .badge-u2r{background:rgba(239,68,68,.12);color:#ef4444;border:1px solid rgba(239,68,68,.25)}
    .badge-model{background:rgba(255,255,255,.06);color:var(--muted);border:1px solid rgba(255,255,255,.08)}
    .empty-state{text-align:center;padding:3rem;color:var(--muted)}
    .empty-state .icon{font-size:2.5rem;margin-bottom:.75rem}
    .empty-state p{font-size:.85rem}

    /* Quick actions */
    .actions-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:2rem}
    .action-card{background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:1.25rem;text-decoration:none;color:var(--text);transition:all .2s;display:flex;align-items:center;gap:1rem}
    .action-card:hover{border-color:var(--accent);transform:translateY(-2px)}
    .action-icon{width:42px;height:42px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0}
    .action-icon.blue{background:rgba(0,212,255,.1)}
    .action-icon.purple{background:rgba(123,47,255,.1)}
    .action-icon.green{background:rgba(34,197,94,.1)}
    .action-text .title{font-size:.9rem;font-weight:700;margin-bottom:.15rem}
    .action-text .sub{font-size:.75rem;color:var(--muted)}

    @media(max-width:900px){
      .sidebar{display:none}
      .main{margin-left:0}
      .charts-grid{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <a href="/dashboard">NIDS<span>.</span>AI</a>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">Main</div>
      <a href="/dashboard" class="nav-item active">
        <span class="icon">📊</span> Dashboard
      </a>
      <a href="/predict" class="nav-item">
        <span class="icon">🔍</span> Run Prediction
      </a>
      <a href="/about" class="nav-item">
        <span class="icon">ℹ️</span> About
      </a>
      <div class="nav-section">History</div>
      <a href="/dashboard/history" class="nav-item">
        <span class="icon">📋</span> Prediction Logs
      </a>
    </nav>
    <div class="sidebar-footer">
      <div class="user-info">
        <div class="avatar">
          <% if (user.avatar) { %>
            <img src="<%= user.avatar %>" alt="avatar">
          <% } else { %>
            <%= user.name.charAt(0).toUpperCase() %>
          <% } %>
        </div>
        <div>
          <div class="user-name"><%= user.name %></div>
          <div class="user-email"><%= user.email %></div>
        </div>
      </div>
      <a href="/auth/logout" class="btn-logout">Sign Out</a>
    </div>
  </aside>

  <!-- Main -->
  <main class="main">
    <div class="page-header">
      <div class="greeting-time" id="greeting-time"></div>
      <h1>Welcome back, <%= user.name.split(' ')[0] %></h1>
      <p>Your network intrusion detection overview</p>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card total">
        <div class="stat-label">Total Predictions</div>
        <div class="stat-value accent"><%= stats.totalPredictions %></div>
        <div class="stat-sub">All time analyses</div>
      </div>
      <div class="stat-card attacks">
        <div class="stat-label">Attacks Detected</div>
        <div class="stat-value red"><%= stats.attackCount %></div>
        <div class="stat-sub">Malicious traffic found</div>
      </div>
      <div class="stat-card normal">
        <div class="stat-label">Normal Traffic</div>
        <div class="stat-value green"><%= stats.normalCount %></div>
        <div class="stat-sub">Benign connections</div>
      </div>
      <div class="stat-card rate">
        <div class="stat-label">Attack Rate</div>
        <div class="stat-value yellow">
          <%= stats.totalPredictions > 0 ? Math.round((stats.attackCount / stats.totalPredictions) * 100) : 0 %>%
        </div>
        <div class="stat-sub">Of all analyzed traffic</div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="actions-grid">
      <a href="/predict" class="action-card">
        <div class="action-icon blue">🔍</div>
        <div class="action-text">
          <div class="title">Analyze Traffic</div>
          <div class="sub">Enter network parameters</div>
        </div>
      </a>
      <a href="/predict#random" class="action-card">
        <div class="action-icon purple">🎲</div>
        <div class="action-text">
          <div class="title">Random Test</div>
          <div class="sub">Test from dataset</div>
        </div>
      </a>
      <a href="/predict#csv" class="action-card">
        <div class="action-icon green">📄</div>
        <div class="action-text">
          <div class="title">Batch Upload</div>
          <div class="sub">CSV file analysis</div>
        </div>
      </a>
    </div>

    <!-- Charts -->
    <% if (stats.totalPredictions > 0) { %>
    <div class="charts-grid">
      <div class="chart-card">
        <div class="chart-title">Traffic Classification</div>
        <canvas id="binaryChart" height="200"></canvas>
      </div>
      <div class="chart-card">
        <div class="chart-title">Attack Type Distribution</div>
        <canvas id="multiChart" height="200"></canvas>
      </div>
    </div>
    <% } %>

    <!-- Recent Predictions -->
    <div class="section-card">
      <div class="section-header">
        <h3>Recent Predictions</h3>
        <a href="/dashboard/history" class="see-all">View all →</a>
      </div>

      <% if (recentPredictions.length === 0) { %>
        <div class="empty-state">
          <div class="icon">🔍</div>
          <p>No predictions yet. <a href="/predict" style="color:var(--accent)">Run your first analysis</a></p>
        </div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Time</th>
              <th>Model</th>
              <th>Type</th>
              <th>Binary Result</th>
              <th>Category</th>
              <th>Confidence</th>
            </tr>
          </thead>
          <tbody>
            <% recentPredictions.forEach(pred => { %>
              <tr>
                <td style="color:var(--muted);font-family:'Space Mono',monospace;font-size:.75rem">
                  <%= new Date(pred.createdAt).toLocaleString() %>
                </td>
                <td><span class="badge badge-model"><%= pred.model.toUpperCase() %></span></td>
                <td style="color:var(--muted);font-size:.8rem"><%= pred.predictionType %></td>
                <td>
                  <span class="badge <%= pred.binaryResult === 'Attack' ? 'badge-attack' : 'badge-normal' %>">
                    <%= pred.binaryResult === 'Attack' ? '⚠️' : '✅' %> <%= pred.binaryResult || '—' %>
                  </span>
                </td>
                <td>
                  <% const cat = pred.attackCategory || pred.multiclassResult || '—';
                     const catClass = {dos:'badge-dos',probe:'badge-probe',r2l:'badge-r2l',u2r:'badge-u2r',normal:'badge-normal',attack:'badge-attack'}[cat.toLowerCase()] || 'badge-model'; %>
                  <span class="badge <%= catClass %>"><%= cat %></span>
                </td>
                <td style="font-family:'Space Mono',monospace;font-size:.8rem">
                  <%= pred.attackProbability ? pred.attackProbability + '%' : '—' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </main>

  <script>
    // Greeting
    const now = new Date();
    const h = now.getHours();
    const g = h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening';
    document.getElementById('greeting-time').textContent =
      g + ' · ' + now.toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric'});

    // Charts
    <% if (stats.totalPredictions > 0) { %>
    const chartDefaults = {
      plugins: { legend: { labels: { color: '#6b7f99', font: { family: 'Syne' } } } },
      responsive: true, maintainAspectRatio: false
    };

    // Binary pie
    new Chart(document.getElementById('binaryChart'), {
      type: 'doughnut',
      data: {
        labels: ['Normal', 'Attack'],
        datasets: [{
          data: [<%= stats.normalCount %>, <%= stats.attackCount %>],
          backgroundColor: ['rgba(34,197,94,0.8)', 'rgba(255,60,110,0.8)'],
          borderColor: ['rgba(34,197,94,0.3)', 'rgba(255,60,110,0.3)'],
          borderWidth: 1
        }]
      },
      options: { ...chartDefaults, cutout: '65%' }
    });

    // Multi chart
    const attackTypes = <%- JSON.stringify(attackTypes) %>;
    const labels = attackTypes.map(a => a._id);
    const data = attackTypes.map(a => a.count);
    const colors = ['rgba(0,212,255,0.8)', 'rgba(255,60,110,0.8)', 'rgba(123,47,255,0.8)', 'rgba(251,146,60,0.8)', 'rgba(34,197,94,0.8)'];

    new Chart(document.getElementById('multiChart'), {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          data,
          backgroundColor: colors.slice(0, labels.length),
          borderRadius: 6
        }]
      },
      options: {
        ...chartDefaults,
        scales: {
          x: { ticks: { color: '#6b7f99' }, grid: { color: 'rgba(255,255,255,0.04)' } },
          y: { ticks: { color: '#6b7f99' }, grid: { color: 'rgba(255,255,255,0.04)' } }
        },
        plugins: { legend: { display: false } }
      }
    });
    <% } %>
  </script>
</body>
</html>
